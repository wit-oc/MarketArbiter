//@version=5
indicator("MarketArbiter Daily SR Map v1 — 3K Authoritative Approx", overlay=true, scale=scale.none, format=format.price, max_bars_back=5000, max_boxes_count=60, max_labels_count=60, max_lines_count=20)

// TradingView operator overlay for MarketArbiter-style daily-major SR regions.
//
// Important boundary:
// - Pine cannot import MarketArbiter's Python selector_surface/authoritative_levels_view directly.
// - This script intentionally mirrors the *selector guardrails* MarketArbiter uses for canonical
//   daily-major zones: 3K-ish working window, confirmed/high-touch zones, minimum strength,
//   spatial separation, max 8 selected zones, and operator-core-style neutral rendering.
// - Exact authoritative production/replay zones still come from MarketArbiter's Surveyor bundle export.
//
// MarketArbiter reference defaults from CanonicalSurveyorConfig:
//   daily_min_meaningful_touches = 5
//   daily_min_zone_separation_bps = 250
//   daily_min_strength = 70
//   daily_max_zones = 8

// -------------------- Inputs --------------------
lookbackBars      = input.int(3000, "SR working window bars", minval=500, maxval=5000)
pivotLen          = input.int(5, "Pivot sensitivity", minval=2, maxval=20)
maxStoredZones    = input.int(40, "Max stored candidate zones", minval=12, maxval=100)
maxVisibleZones   = input.int(8, "Max selected daily-major zones", minval=1, maxval=8)
minTouches        = input.int(5, "Min meaningful touches", minval=2, maxval=20)
minStrength       = input.float(70.0, "Min selection strength", minval=0.0, maxval=100.0, step=1.0)
minSeparationBps  = input.float(250.0, "Min zone separation (bps)", minval=25.0, maxval=1000.0, step=25.0)
zoneAtrMult       = input.float(0.25, "Operator core half-width ATR", minval=0.05, maxval=1.00, step=0.05)
minZoneWidthBps   = input.float(15.0, "Min core half-width (bps)", minval=1.0, maxval=100.0, step=1.0)
clusterAtrMult    = input.float(1.10, "Merge/cluster tolerance ATR", minval=0.10, maxval=3.00, step=0.05)
touchGapBars      = input.int(8, "Min bars between touch counts", minval=1, maxval=100)
extendBars        = input.int(200, "Extend zones right bars", minval=10, maxval=500)
showLabels        = input.bool(false, "Show compact labels")
showTfWarning     = input.bool(true, "Warn when chart is not daily")

// -------------------- Constants --------------------
DIR_SUPPORT = 1
DIR_RESIST  = -1

// Neutral visual style: these are operator regions, not buy/sell buttons.
ZONE_FILL   = color.new(color.silver, 88)
ZONE_BORDER = color.new(color.silver, 45)
LABEL_BG    = color.new(color.black, 20)
LABEL_TEXT  = color.white

// -------------------- Series --------------------
atr = ta.atr(14)
ph = ta.pivothigh(high, pivotLen, pivotLen)
pl = ta.pivotlow(low, pivotLen, pivotLen)

// -------------------- Zone store --------------------
var zTop       = array.new_float()
var zBot       = array.new_float()
var zMid       = array.new_float()
var zDir       = array.new_int()
var zTouches   = array.new_int()
var zBirthBar  = array.new_int()
var zLastTouch = array.new_int()
var zLastPivot = array.new_int()
var zBox       = array.new_box()
var zLabel     = array.new_label()
var tfWarn     = label.new(na, na, "", xloc=xloc.bar_index, style=label.style_label_down, textcolor=color.white, color=color.new(color.orange, 0), size=size.small)

f_delete_drawings(_i) =>
    b = array.get(zBox, _i)
    l = array.get(zLabel, _i)
    if not na(b)
        box.delete(b)
    if not na(l)
        label.delete(l)

f_remove_zone(_i) =>
    f_delete_drawings(_i)
    array.remove(zTop, _i)
    array.remove(zBot, _i)
    array.remove(zMid, _i)
    array.remove(zDir, _i)
    array.remove(zTouches, _i)
    array.remove(zBirthBar, _i)
    array.remove(zLastTouch, _i)
    array.remove(zLastPivot, _i)
    array.remove(zBox, _i)
    array.remove(zLabel, _i)

f_intervals_overlap(_topA, _botA, _topB, _botB, _tol) =>
    not (_topA < _botB - _tol or _botA > _topB + _tol)

f_zone_strength(_i) =>
    touches = array.get(zTouches, _i)
    age = math.max(1, bar_index - array.get(zBirthBar, _i))
    lastTouchAge = math.max(0, bar_index - array.get(zLastTouch, _i))
    mid = array.get(zMid, _i)
    width = math.max(array.get(zTop, _i) - array.get(zBot, _i), syminfo.mintick)
    widthBps = mid > 0 ? width / mid * 10000.0 : 9999.0
    touchScore = math.min(50.0, touches * 8.0)
    recencyScore = math.max(0.0, 18.0 * (1.0 - age / lookbackBars))
    activeTouchScore = math.max(0.0, 14.0 * (1.0 - lastTouchAge / lookbackBars))
    widthScore = math.max(0.0, 18.0 * (1.0 - widthBps / 900.0))
    math.min(100.0, touchScore + recencyScore + activeTouchScore + widthScore)

f_rank(_i) =>
    score = f_zone_strength(_i)
    r = 1
    n = array.size(zMid)
    if n > 0
        for j = 0 to n - 1
            if j != _i and f_zone_strength(j) > score
                r += 1
    r

f_gap_bps(_i, _j) =>
    midA = array.get(zMid, _i)
    midB = array.get(zMid, _j)
    ref = math.max(math.abs(midA), syminfo.mintick)
    math.abs(midA - midB) / ref * 10000.0

f_is_confirmed(_i) =>
    bar_index - array.get(zBirthBar, _i) <= lookbackBars and array.get(zTouches, _i) >= minTouches and f_zone_strength(_i) >= minStrength

f_has_stronger_nearby(_i) =>
    stronger = false
    n = array.size(zMid)
    if n > 0
        for j = 0 to n - 1
            if j != _i and f_is_confirmed(j) and f_gap_bps(_i, j) < minSeparationBps
                better = f_zone_strength(j) > f_zone_strength(_i) or (f_zone_strength(j) == f_zone_strength(_i) and array.get(zTouches, j) > array.get(zTouches, _i))
                if better
                    stronger := true
    stronger

f_selected_rank(_i) =>
    // Count only confirmed, spatially-separated representatives ahead of this zone.
    if not f_is_confirmed(_i) or f_has_stronger_nearby(_i)
        999
    else
        score = f_zone_strength(_i)
        r = 1
        n = array.size(zMid)
        if n > 0
            for j = 0 to n - 1
                if j != _i and f_is_confirmed(j) and not f_has_stronger_nearby(j)
                    if f_zone_strength(j) > score
                        r += 1
        r

f_add_or_merge_zone(_dir, _price, _pivotBar, _atrRef) =>
    half = math.max(_atrRef * zoneAtrMult, _price * minZoneWidthBps / 10000.0)
    top = _price + half
    bot = _price - half
    mid = _price
    tol = math.max(_atrRef * clusterAtrMult, _price * minSeparationBps / 10000.0)
    best = -1
    bestDist = 10e10
    n = array.size(zMid)
    if n > 0
        for i = 0 to n - 1
            sameDir = array.get(zDir, i) == _dir
            inWindow = bar_index - array.get(zBirthBar, i) <= lookbackBars
            zt = array.get(zTop, i)
            zb = array.get(zBot, i)
            zm = array.get(zMid, i)
            closeEnough = math.abs(zm - mid) <= tol or f_intervals_overlap(zt, zb, top, bot, tol)
            if sameDir and inWindow and closeEnough
                d = math.abs(zm - mid)
                if d < bestDist
                    bestDist := d
                    best := i
    if best >= 0
        oldTouches = array.get(zTouches, best)
        newTouches = oldTouches + 1
        oldMid = array.get(zMid, best)
        newMid = (oldMid * oldTouches + mid) / newTouches
        // Keep operator-core bounds compact instead of letting old boxes balloon forever.
        newHalf = math.max(_atrRef * zoneAtrMult, newMid * minZoneWidthBps / 10000.0)
        array.set(zTop, best, newMid + newHalf)
        array.set(zBot, best, newMid - newHalf)
        array.set(zMid, best, newMid)
        array.set(zTouches, best, newTouches)
        array.set(zLastPivot, best, _pivotBar)
    else
        array.push(zTop, top)
        array.push(zBot, bot)
        array.push(zMid, mid)
        array.push(zDir, _dir)
        array.push(zTouches, 1)
        array.push(zBirthBar, _pivotBar)
        array.push(zLastTouch, _pivotBar)
        array.push(zLastPivot, _pivotBar)
        array.push(zBox, na)
        array.push(zLabel, na)

// -------------------- Ingest confirmed pivots --------------------
if not na(ph)
    f_add_or_merge_zone(DIR_RESIST, ph, bar_index - pivotLen, nz(atr[pivotLen], atr))

if not na(pl)
    f_add_or_merge_zone(DIR_SUPPORT, pl, bar_index - pivotLen, nz(atr[pivotLen], atr))

// -------------------- Update lifecycle --------------------
nZones = array.size(zMid)
if nZones > 0
    for i = nZones - 1 to 0
        expired = bar_index - array.get(zBirthBar, i) > lookbackBars
        overflow = array.size(zMid) > maxStoredZones and f_rank(i) > maxStoredZones
        if expired or overflow
            f_remove_zone(i)
        else
            top = array.get(zTop, i)
            bot = array.get(zBot, i)
            touched = high >= bot and low <= top
            if touched and bar_index - array.get(zLastTouch, i) >= touchGapBars
                array.set(zTouches, i, array.get(zTouches, i) + 1)
                array.set(zLastTouch, i, bar_index)

// -------------------- Render on terminal bar --------------------
if barstate.islast
    if showTfWarning and not timeframe.isdaily
        label.set_x(tfWarn, bar_index)
        label.set_y(tfWarn, high)
        label.set_text(tfWarn, "MarketArbiter SR map is calibrated for 1D charts")
    else
        label.set_x(tfWarn, na)
        label.set_y(tfWarn, na)
        label.set_text(tfWarn, "")

    nDraw = array.size(zMid)
    if nDraw > 0
        for i = 0 to nDraw - 1
            selRank = f_selected_rank(i)
            visible = selRank <= maxVisibleZones
            b = array.get(zBox, i)
            l = array.get(zLabel, i)
            if visible
                top = array.get(zTop, i)
                bot = array.get(zBot, i)
                mid = array.get(zMid, i)
                touches = array.get(zTouches, i)
                left = math.max(array.get(zBirthBar, i), bar_index - lookbackBars)
                right = bar_index + extendBars
                if na(b)
                    b := box.new(left, top, right, bot, xloc=xloc.bar_index, bgcolor=ZONE_FILL, border_color=ZONE_BORDER)
                    array.set(zBox, i, b)
                else
                    box.set_left(b, left)
                    box.set_right(b, right)
                    box.set_top(b, top)
                    box.set_bottom(b, bot)
                    box.set_bgcolor(b, ZONE_FILL)
                    box.set_border_color(b, ZONE_BORDER)
                if showLabels
                    txt = "MA SR #" + str.tostring(selRank) + " • " + str.tostring(touches) + "t • " + str.tostring(math.round(f_zone_strength(i)))
                    if na(l)
                        l := label.new(right, mid, txt, xloc=xloc.bar_index, style=label.style_label_left, textcolor=LABEL_TEXT, color=LABEL_BG, size=size.small)
                        array.set(zLabel, i, l)
                    else
                        label.set_x(l, right)
                        label.set_y(l, mid)
                        label.set_text(l, txt)
                        label.set_color(l, LABEL_BG)
                        label.set_textcolor(l, LABEL_TEXT)
                else if not na(l)
                    label.delete(l)
                    array.set(zLabel, i, na)
            else
                if not na(b)
                    box.delete(b)
                    array.set(zBox, i, na)
                if not na(l)
                    label.delete(l)
                    array.set(zLabel, i, na)
