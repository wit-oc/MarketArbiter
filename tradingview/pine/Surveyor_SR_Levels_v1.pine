//@version=5
indicator("Surveyor SR Levels v1 — parity scaffold", overlay=true, scale=scale.none, format=format.price, max_bars_back=6000, max_boxes_count=80, max_labels_count=120)

// T3 parity scaffold only.
// This file intentionally stops before any candidate-generation or daily-major selection logic.
// T4-T6 will populate the zone store using the exact Python parity map captured in
// docs/PINE_SURVEYOR_SR_PARITY_MAP_V1.md.

// -------------------- Inputs --------------------
showDebugTable = input.bool(true, "Show parity debug table")
showSelectedZoneLabels = input.bool(true, "Show selected-zone labels")
showScaffoldNotice = input.bool(true, "Show scaffold notice when no selected zones exist")
renderSelectedLimit = input.int(8, "Render cap for selected zones", minval=1, maxval=8)
renderExtendBars = input.int(200, "Extend rendered zones right bars", minval=10, maxval=600)
minHistoryBars = input.int(365, "Minimum daily bars for authoritative parity", minval=100, maxval=5000)

// -------------------- Neutral visuals --------------------
ZONE_FILL = color.new(color.silver, 88)
ZONE_BORDER = color.new(color.silver, 42)
LABEL_BG = color.new(color.black, 20)
LABEL_TEXT = color.white
NOTICE_BG = color.new(color.orange, 15)
NOTICE_TEXT = color.white
TABLE_BG = color.new(color.black, 0)
TABLE_HEADER_BG = color.new(color.silver, 78)
TABLE_VALUE_BG = color.new(color.black, 82)

// -------------------- Runtime counters --------------------
var int structureCandidateCount = 0
var int baseCandidateCount = 0
var int reactionCandidateCount = 0
var int mergedZoneCount = 0
var int scoredZoneCount = 0
var int selectedZoneCount = 0

// -------------------- Structure-event staging --------------------
var string[] structureEventName = array.new_string()
var int[] structureEventIndex = array.new_int()
var float[] structureEventPrice = array.new_float()
var string[] structureEventRegime = array.new_string()
var string[] structureEventReason = array.new_string()
var int[] structureEventAnchorIndex = array.new_int()
var float[] structureEventAnchorPrice = array.new_float()

// -------------------- Zone storage --------------------
var string[] zoneId = array.new_string()
var string[] zoneSymbol = array.new_string()
var string[] zoneTf = array.new_string()
var string[] zoneStatus = array.new_string()
var string[] zoneCandidateFamily = array.new_string()
var string[] zoneSourceFamily = array.new_string()
var string[] zoneSourceVersion = array.new_string()
var string[] zoneEngineContract = array.new_string()
var float[] zoneLow = array.new_float()
var float[] zoneHigh = array.new_float()
var float[] zoneMid = array.new_float()
var string[] zoneKind = array.new_string()
var string[] zoneOriginKind = array.new_string()
var string[] zoneCurrentRole = array.new_string()
var string[] zoneRelativePosition = array.new_string()
var float[] zoneStrengthScore = array.new_float()
var float[] zoneReactionScore = array.new_float()
var float[] zoneReactionEfficiencyScore = array.new_float()
var float[] zoneCarryScore = array.new_float()
var float[] zoneBodyRespectScore = array.new_float()
var float[] zoneSelectionScore = array.new_float()
var float[] zoneFamilyConfluenceBonus = array.new_float()
var float[] zoneDailyProvenanceWeight = array.new_float()
var float[] zoneRetestWeight = array.new_float()
var int[] zonePivotCount = array.new_int()
var int[] zoneTouchCount = array.new_int()
var int[] zoneMeaningfulTouchCount = array.new_int()
var int[] zoneMergeFamilyCount = array.new_int()
var int[] zoneMergeCandidateCount = array.new_int()
var float[] zoneWidthBps = array.new_float()
var float[] zoneWidthAtr = array.new_float()
var float[] zoneBodyOverlapRate = array.new_float()
var float[] zoneWickOnlyRate = array.new_float()
var float[] zoneCloseInsideRate = array.new_float()
var float[] zoneDirectionalCloseRate = array.new_float()
var float[] zoneCounterCloseRate = array.new_float()
var string[] zoneFirstTouchState = array.new_string()
var bool[] zoneFirstRetestPending = array.new_bool()
var int[] zoneFirstRetestBar = array.new_int()
var string[] zoneFirstRetestResult = array.new_string()
var bool[] zoneDeviationRetest = array.new_bool()
var bool[] zoneHasStructure = array.new_bool()
var bool[] zoneHasBase = array.new_bool()
var bool[] zoneHasReaction = array.new_bool()
var bool[] zonePureBaseOnly = array.new_bool()
var string[] zoneSelectorSurface = array.new_string()
var string[] zoneSelectorStatus = array.new_string()
var string[] zoneSelectorReason = array.new_string()
var int[] zoneSelectorRank = array.new_int()
var float[] zoneCoreLow = array.new_float()
var float[] zoneCoreHigh = array.new_float()
var float[] zoneCoreMid = array.new_float()
var string[] zoneCoreDefinition = array.new_string()
var string[] zoneDailyPocketId = array.new_string()
var int[] zoneDailyPocketMemberCount = array.new_int()

// Draw objects are aligned 1:1 with the zone arrays above.
var box[] zoneBox = array.new_box()
var label[] zoneLabel = array.new_label()
var table debugTable = table.new(position.top_right, 2, 11, frame_color=color.new(color.silver, 65), border_width=1)

// -------------------- Helpers --------------------
f_zone_store_size() =>
    array.size(zoneId)

f_price_text(_value) =>
    na(_value) ? "na" : str.tostring(_value, format.mintick)

f_family_summary(_i) =>
    text = ""
    if array.get(zoneHasStructure, _i)
        text := text + "structure"
    if array.get(zoneHasBase, _i)
        text := text + (text == "" ? "" : "+") + "base"
    if array.get(zoneHasReaction, _i)
        text := text + (text == "" ? "" : "+") + "reaction"
    text == "" ? "none" : text

f_visible_selected_zone(_i) =>
    array.get(zoneSelectorStatus, _i) == "kept" and array.get(zoneSelectorRank, _i) > 0 and array.get(zoneSelectorRank, _i) <= renderSelectedLimit and not na(array.get(zoneCoreLow, _i)) and not na(array.get(zoneCoreHigh, _i))

f_append_structure_event(_eventName, _eventIndex, _eventPrice, _eventRegime, _eventReason, _anchorIndex, _anchorPrice) =>
    array.push(structureEventName, _eventName)
    array.push(structureEventIndex, _eventIndex)
    array.push(structureEventPrice, _eventPrice)
    array.push(structureEventRegime, _eventRegime)
    array.push(structureEventReason, _eventReason)
    array.push(structureEventAnchorIndex, _anchorIndex)
    array.push(structureEventAnchorPrice, _anchorPrice)

f_append_blank_zone(_zoneId, _zoneKind) =>
    array.push(zoneId, _zoneId)
    array.push(zoneSymbol, syminfo.tickerid)
    array.push(zoneTf, timeframe.period)
    array.push(zoneStatus, "candidate")
    array.push(zoneCandidateFamily, "")
    array.push(zoneSourceFamily, "")
    array.push(zoneSourceVersion, "")
    array.push(zoneEngineContract, "")
    array.push(zoneLow, na)
    array.push(zoneHigh, na)
    array.push(zoneMid, na)
    array.push(zoneKind, _zoneKind)
    array.push(zoneOriginKind, _zoneKind)
    array.push(zoneCurrentRole, "")
    array.push(zoneRelativePosition, "")
    array.push(zoneStrengthScore, na)
    array.push(zoneReactionScore, na)
    array.push(zoneReactionEfficiencyScore, na)
    array.push(zoneCarryScore, na)
    array.push(zoneBodyRespectScore, na)
    array.push(zoneSelectionScore, na)
    array.push(zoneFamilyConfluenceBonus, na)
    array.push(zoneDailyProvenanceWeight, na)
    array.push(zoneRetestWeight, na)
    array.push(zonePivotCount, 0)
    array.push(zoneTouchCount, 0)
    array.push(zoneMeaningfulTouchCount, 0)
    array.push(zoneMergeFamilyCount, 0)
    array.push(zoneMergeCandidateCount, 0)
    array.push(zoneWidthBps, na)
    array.push(zoneWidthAtr, na)
    array.push(zoneBodyOverlapRate, na)
    array.push(zoneWickOnlyRate, na)
    array.push(zoneCloseInsideRate, na)
    array.push(zoneDirectionalCloseRate, na)
    array.push(zoneCounterCloseRate, na)
    array.push(zoneFirstTouchState, "")
    array.push(zoneFirstRetestPending, false)
    array.push(zoneFirstRetestBar, -1)
    array.push(zoneFirstRetestResult, "")
    array.push(zoneDeviationRetest, false)
    array.push(zoneHasStructure, false)
    array.push(zoneHasBase, false)
    array.push(zoneHasReaction, false)
    array.push(zonePureBaseOnly, false)
    array.push(zoneSelectorSurface, "")
    array.push(zoneSelectorStatus, "")
    array.push(zoneSelectorReason, "")
    array.push(zoneSelectorRank, 0)
    array.push(zoneCoreLow, na)
    array.push(zoneCoreHigh, na)
    array.push(zoneCoreMid, na)
    array.push(zoneCoreDefinition, "")
    array.push(zoneDailyPocketId, "")
    array.push(zoneDailyPocketMemberCount, 0)
    array.push(zoneBox, na)
    array.push(zoneLabel, na)

f_delete_zone_drawings(_i) =>
    existingBox = array.get(zoneBox, _i)
    existingLabel = array.get(zoneLabel, _i)
    if not na(existingBox)
        box.delete(existingBox)
        array.set(zoneBox, _i, na)
    if not na(existingLabel)
        label.delete(existingLabel)
        array.set(zoneLabel, _i, na)

f_render_selected_zones() =>
    storeSize = f_zone_store_size()
    visibleCount = 0
    if storeSize > 0
        for i = 0 to storeSize - 1
            if f_visible_selected_zone(i)
                visibleCount += 1
                leftIndex = int(math.max(0, bar_index - minHistoryBars))
                rightIndex = bar_index + renderExtendBars
                topPrice = array.get(zoneCoreHigh, i)
                bottomPrice = array.get(zoneCoreLow, i)
                midPrice = na(array.get(zoneCoreMid, i)) ? (topPrice + bottomPrice) * 0.5 : array.get(zoneCoreMid, i)
                boxText = "SR #" + str.tostring(array.get(zoneSelectorRank, i)) + " " + array.get(zoneKind, i)
                existingBox = array.get(zoneBox, i)
                if na(existingBox)
                    existingBox := box.new(leftIndex, topPrice, rightIndex, bottomPrice, xloc=xloc.bar_index, bgcolor=ZONE_FILL, border_color=ZONE_BORDER)
                    array.set(zoneBox, i, existingBox)
                else
                    box.set_left(existingBox, leftIndex)
                    box.set_right(existingBox, rightIndex)
                    box.set_top(existingBox, topPrice)
                    box.set_bottom(existingBox, bottomPrice)
                    box.set_bgcolor(existingBox, ZONE_FILL)
                    box.set_border_color(existingBox, ZONE_BORDER)
                    box.set_text(existingBox, boxText)
                    box.set_text_color(existingBox, LABEL_TEXT)
                if showSelectedZoneLabels
                    labelText = "SR #" + str.tostring(array.get(zoneSelectorRank, i)) + " · " + array.get(zoneKind, i) + "\n" + f_family_summary(i) + "\n" + f_price_text(bottomPrice) + " → " + f_price_text(topPrice)
                    existingLabel = array.get(zoneLabel, i)
                    if na(existingLabel)
                        existingLabel := label.new(rightIndex, midPrice, labelText, xloc=xloc.bar_index, style=label.style_label_left, textcolor=LABEL_TEXT, color=LABEL_BG, size=size.small)
                        array.set(zoneLabel, i, existingLabel)
                    else
                        label.set_x(existingLabel, rightIndex)
                        label.set_y(existingLabel, midPrice)
                        label.set_text(existingLabel, labelText)
                        label.set_textcolor(existingLabel, LABEL_TEXT)
                        label.set_color(existingLabel, LABEL_BG)
                else
                    existingLabel = array.get(zoneLabel, i)
                    if not na(existingLabel)
                        label.delete(existingLabel)
                        array.set(zoneLabel, i, na)
            else
                f_delete_zone_drawings(i)
    visibleCount

f_update_debug_table(_visibleCount) =>
    if showDebugTable
        table.cell(debugTable, 0, 0, "Field", bgcolor=TABLE_HEADER_BG, text_color=color.black)
        table.cell(debugTable, 1, 0, "Value", bgcolor=TABLE_HEADER_BG, text_color=color.black)
        table.cell(debugTable, 0, 1, "Stage", bgcolor=TABLE_BG, text_color=LABEL_TEXT)
        table.cell(debugTable, 1, 1, "T3 scaffold", bgcolor=TABLE_VALUE_BG, text_color=LABEL_TEXT)
        table.cell(debugTable, 0, 2, "Timeframe", bgcolor=TABLE_BG, text_color=LABEL_TEXT)
        table.cell(debugTable, 1, 2, timeframe.period + (timeframe.isdaily ? "" : " (expect 1D)"), bgcolor=TABLE_VALUE_BG, text_color=LABEL_TEXT)
        table.cell(debugTable, 0, 3, "Bars loaded", bgcolor=TABLE_BG, text_color=LABEL_TEXT)
        table.cell(debugTable, 1, 3, str.tostring(bar_index + 1), bgcolor=TABLE_VALUE_BG, text_color=LABEL_TEXT)
        table.cell(debugTable, 0, 4, "Structure cands", bgcolor=TABLE_BG, text_color=LABEL_TEXT)
        table.cell(debugTable, 1, 4, str.tostring(structureCandidateCount), bgcolor=TABLE_VALUE_BG, text_color=LABEL_TEXT)
        table.cell(debugTable, 0, 5, "Base cands", bgcolor=TABLE_BG, text_color=LABEL_TEXT)
        table.cell(debugTable, 1, 5, str.tostring(baseCandidateCount), bgcolor=TABLE_VALUE_BG, text_color=LABEL_TEXT)
        table.cell(debugTable, 0, 6, "Reaction cands", bgcolor=TABLE_BG, text_color=LABEL_TEXT)
        table.cell(debugTable, 1, 6, str.tostring(reactionCandidateCount), bgcolor=TABLE_VALUE_BG, text_color=LABEL_TEXT)
        table.cell(debugTable, 0, 7, "Merged / scored", bgcolor=TABLE_BG, text_color=LABEL_TEXT)
        table.cell(debugTable, 1, 7, str.tostring(mergedZoneCount) + " / " + str.tostring(scoredZoneCount), bgcolor=TABLE_VALUE_BG, text_color=LABEL_TEXT)
        table.cell(debugTable, 0, 8, "Selected visible", bgcolor=TABLE_BG, text_color=LABEL_TEXT)
        table.cell(debugTable, 1, 8, str.tostring(_visibleCount), bgcolor=TABLE_VALUE_BG, text_color=LABEL_TEXT)
        table.cell(debugTable, 0, 9, "Zone store size", bgcolor=TABLE_BG, text_color=LABEL_TEXT)
        table.cell(debugTable, 1, 9, str.tostring(f_zone_store_size()), bgcolor=TABLE_VALUE_BG, text_color=LABEL_TEXT)
        table.cell(debugTable, 0, 10, "Note", bgcolor=TABLE_BG, text_color=LABEL_TEXT)
        table.cell(debugTable, 1, 10, "Storage + renderer only; T4-T6 will populate candidates and selections.", bgcolor=TABLE_VALUE_BG, text_color=LABEL_TEXT)

var label scaffoldNotice = na

f_update_scaffold_notice(_visibleCount) =>
    if showScaffoldNotice and _visibleCount == 0
        noticeText = bar_index + 1 < minHistoryBars ? "Surveyor SR parity scaffold\nWaiting for min history bars and T4-T6 logic." : "Surveyor SR parity scaffold\nNo selected zones yet — candidate/selector ports land in T4-T6."
        y = high + math.max(ta.atr(14), syminfo.mintick) * 0.6
        if na(scaffoldNotice)
            scaffoldNotice := label.new(bar_index, y, noticeText, xloc=xloc.bar_index, style=label.style_label_down, textcolor=NOTICE_TEXT, color=NOTICE_BG, size=size.small)
        else
            label.set_x(scaffoldNotice, bar_index)
            label.set_y(scaffoldNotice, y)
            label.set_text(scaffoldNotice, noticeText)
            label.set_textcolor(scaffoldNotice, NOTICE_TEXT)
            label.set_color(scaffoldNotice, NOTICE_BG)
    else
        if not na(scaffoldNotice)
            label.delete(scaffoldNotice)
            scaffoldNotice := na

// -------------------- Terminal-bar rendering --------------------
if barstate.islast
    selectedZoneCount := 0
    visibleCount = f_render_selected_zones()
    selectedZoneCount := visibleCount
    f_update_debug_table(visibleCount)
    f_update_scaffold_notice(visibleCount)
